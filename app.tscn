[node name="tooltip_ball" parent="bgpanel/spacer/content/left bar/spacer/content/HBoxContainer" unique_id=1954223543 instance=ExtResource("4_nee2x")]
layout_mode = 2
tooltip = "This editor doesn't use the archipelago codebase, instead it directly parses archipelago YAML files into the editor. this means the editor is not aware of the items or locations for the selected games. as a consequence, options with lists that allow to enable/disable things like items or locations need to be filled in manually without any autocorrect or error check if the item/location actually exists. it's still possibe to edit the values, you just need to know the names of the checks or items you want to fill in."

