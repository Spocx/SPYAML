layout_mode = 2
size_flags_vertical = 6
tooltip = "[color=#fab387]       /[/color] [color=#a6e3a1][b]SP-YAML version 1.0[/b][/color]
[color=#fab387]      |[/color] sp-yaml is a yaml editing tool for archipelago yaml
[color=#fab387]      |[/color] option files. It's not built on top of the archipelago
[color=#fab387]      |[/color] codebase and is a direct yaml parser/encoder.
[color=#fab387]      |[/color] This means you won't have any autocorrect tools 
[color=#fab387]      |[/color] for things like location or item lists, but it does offer 
[color=#fab387]      |[/color] more control and option types than the built in
[color=#fab387]      |[/color] archipelago option editor. it's also more compact
 [color=#fab387]      \\[/color] and easy to naviagate
[color=#fab387]     /[/color]
[color=#fab387][b]₍^. .^₎⟆[/b][/color]"

